    {
      "id": "DrnZaPD-EDuaHGoiajaie",
      "type": "text",
      "x": 547.0245607779929,
      "y": 468.2313837719435,
      "width": 257.14918193709707,
      "height": 130,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "b0thV4h-Y57tZLhUAlm2U"
      ],
      "frameId": null,
      "index": "aV",
      "roundness": null,
      "seed": 118490135,
      "version": 1360,
      "versionNonce": 64391175,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1774364867214,
      "link": null,
      "locked": false,
      "text": "on new client connection...\n- write socket to list with property\nto indicate that it is not ready to\nsend or receive msgs yet\n- wait for client to send chat ID\n    - if not sent within 15s, dc client\n- when ID received, toggle socket on\n- subscribe to redis event chat-{id}",
      "fontSize": 13,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "on new client connection...\n- write socket to list with property\nto indicate that it is not ready to\nsend or receive msgs yet\n- wait for client to send chat ID\n    - if not sent within 15s, dc client\n- when ID received, toggle socket on\n- subscribe to redis event chat-{id}",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "reBfByUeset3Vb7hTSzwa",
      "type": "text",
      "x": 547.3756698199551,
      "y": 610.6594614740449,
      "width": 246.40225219726562,
      "height": 97.5,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dotted",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "b0thV4h-Y57tZLhUAlm2U"
      ],
      "frameId": null,
      "index": "aW",
      "roundness": null,
      "seed": 18643447,
      "version": 747,
      "versionNonce": 2074309961,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1774364871056,
      "link": null,
      "locked": false,
      "text": "on client disconnect...\n- delete socket from record\n- check if any other sockets in the\nrecord have a chat ID of the same ID\n    - if so, unsubscribe from respective\n    redis pub/sub channel",
      "fontSize": 13,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "on client disconnect...\n- delete socket from record\n- check if any other sockets in the\nrecord have a chat ID of the same ID\n    - if so, unsubscribe from respective\n    redis pub/sub channel",
      "autoResize": true,
      "lineHeight": 1.25
    },
