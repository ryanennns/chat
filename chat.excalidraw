      "type": "text",
      "x": -232.89924287254496,
      "y": -194.7275488138023,
      "width": 290.7250061035156,
      "height": 330.568682500694,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "fL2ieFwVNQKoblxRTDJU5"
      ],
      "frameId": null,
      "index": "amV",
