    {
      "id": "EZ6_bEafZ77MSGzuCjSb5",
      "type": "text",
      "x": 105.02757245134819,
      "y": -201.2512790834526,
      "width": 228.80047607421875,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "w-GizPOu-rjA354qmIN0q"
      ],
      "frameId": null,
      "index": "ah",
      "roundness": null,
      "seed": 1912403945,
      "version": 475,
      "versionNonce": 141755463,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774366069138,
      "link": null,
      "locked": false,
      "text": "GET    /servers/provision\ngets lowest load server,\nreturns the ID\n\nPOST   /servers/create\nfor debug; creates new\nserver and returns ID/url\n\nDELETE /servers/delete\nfor debug; deletes random\nwss server\n\nGET    /redis-stats\nfor client; returns server\n& chat room state",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "GET    /servers/provision\ngets lowest load server,\nreturns the ID\n\nPOST   /servers/create\nfor debug; creates new\nserver and returns ID/url\n\nDELETE /servers/delete\nfor debug; deletes random\nwss server\n\nGET    /redis-stats\nfor client; returns server\n& chat room state",
      "autoResize": true,
      "lineHeight": 1.25
    },
